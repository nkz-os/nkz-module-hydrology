# =============================================================================
# NKZ Water Studio — Environment Configuration
# =============================================================================
# Copy to .env for local development. Never commit .env to git.
# =============================================================================

# --- Frontend (Vite dev server) -----------------------------------------------

# Point Vite's /api proxy to a running API. No default to avoid hardcoded URLs.
VITE_PROXY_TARGET=https://your-api-domain

# --- Backend ------------------------------------------------------------------

APP_NAME=NKZ Water Studio
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1/hydrology

# CORS: comma-separated JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5003","http://localhost:5173"]

# --- Keycloak / JWT -----------------------------------------------------------

KEYCLOAK_URL=https://auth.your-domain/auth
KEYCLOAK_REALM=nekazari
JWT_AUDIENCE=account

# Optional: override full issuer URL instead of deriving from KEYCLOAK_URL
# JWT_ISSUER=https://auth.your-domain/auth/realms/nekazari

# --- Service-to-service (optional) -------------------------------------------
# MODULE_MANAGEMENT_KEY=your-secret-key

# --- Database (uncomment if your module uses PostgreSQL) ---------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# --- Redis / RQ --------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- MinIO / S3 --------------------------------------------------------------
MINIO_ENDPOINT=http://minio-service:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=nkz-hydrology
MINIO_REGION=us-east-1

# --- Hydrology-specific ------------------------------------------------------
OPENMETEO_CACHE_TTL_DAYS=1
DEM_MAX_SIZE_MB=50
WORKER_TIMEOUT=600
